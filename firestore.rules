rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return getUserData().role == role;
    }

    function isHost()      { return hasRole('host'); }
    function isVolunteer() { return hasRole('volunteer'); }
    function isProvider()  { return hasRole('provider'); }
    function isAttendee()  { return hasRole('attendee'); }

    // ── Users ──────────────────────────────────────────────────
    match /users/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isHost());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (request.auth.uid == uid || isHost());
    }

    // ── Events & sub-collections ───────────────────────────────
    match /events/{eventId} {
      allow read:  if isSignedIn();
      allow write: if isHost();

      match /gates/{gateId} {
        allow read:  if isSignedIn();
        allow write: if isHost() || isVolunteer();
      }

      match /zones/{zoneId} {
        allow read:  if isSignedIn();
        allow write: if isHost();
      }
    }

    // ── Attendees ──────────────────────────────────────────────
    match /attendees/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isHost() || isVolunteer());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && (isHost() || isVolunteer() || request.auth.uid == uid);
    }

    // ── Volunteers ─────────────────────────────────────────────
    match /volunteers/{uid} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
    }

    // ── Stalls ─────────────────────────────────────────────────
    match /stalls/{stallId} {
      allow read:  if isSignedIn();
      allow write: if isHost() || (isProvider() && resource.data.providerId == request.auth.uid);
    }

    // ── Missions ───────────────────────────────────────────────
    match /missions/{missionId} {
      allow read:   if isSignedIn();
      allow create: if isHost();
      allow update: if isHost() || isVolunteer();
    }

    // ── Orders ─────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read:   if isSignedIn() && (
        isHost() ||
        resource.data.attendeeId == request.auth.uid ||
        isProvider()
      );
      allow create: if isAttendee();
      allow update: if isHost() || isProvider();
    }
  }
}
